{
  "rewrites": [
    { "source": "/config.js",       "destination": "/api/config" },
    { "source": "/map/:id/admin",   "destination": "/api/map-admin/:id" },
    { "source": "/map/:id",         "destination": "/api/map/:id" }
  ],
  "redirects": [
    { "source": "/",                "destination": "/maintenance.html", "permanent": false },
    { "source": "/map/:id",         "destination": "/maintenance.html", "permanent": false },
    { "source": "/((?!maintenance|api|_next|favicon).*)", "destination": "/maintenance.html", "permanent": false }
  ]
}
